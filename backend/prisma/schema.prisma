model Plan {
  id              String          @id @default(uuid()) @db.Uuid
  code            String          @unique
  name            String
  description     String?
  priceCents      Int             @default(0) @map("price_cents")
  currency        String          @default("CNY")
  interval        PlanInterval    @default(MONTH)
  seatLimit       Int?            @map("seat_limit")
  projectLimit    Int?            @map("project_limit")
  questionLimit   Int?            @map("question_limit")
  aiMonitorLimit  Int?            @map("ai_monitor_limit")
  contentLimit    Int?            @map("content_limit")
  reportLimit     Int?            @map("report_limit")
  aiTokenLimit    Int?            @map("ai_token_limit")
  modelDispatchLimit Int?         @map("model_dispatch_limit")
  teamMemberLimit Int?            @map("team_member_limit")
  distributionEnabled Boolean     @default(false) @map("distribution_enabled")
  advancedCompetitorAnalysisEnabled Boolean @default(false) @map("advanced_competitor_analysis_enabled")
  autoOptimizationEnabled Boolean @default(false) @map("auto_optimization_enabled")
  featureFlags    Json?           @map("feature_flags")
  active          Boolean         @default(true)
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  subscriptions   Subscription[]
  orders          Order[]
  subscriptionOrders SubscriptionOrder[]

  @@map("plans")
}

model Subscription {
  id                    String             @id @default(uuid()) @db.Uuid
  organizationId        String             @map("organization_id") @db.Uuid
  planId                String             @map("plan_id") @db.Uuid
  status                SubscriptionStatus @default(TRIALING)
  provider              PaymentProvider?   @default(MANUAL)
  externalSubscriptionId String?            @map("external_subscription_id")
  currentPeriodStart    DateTime?          @map("current_period_start")
  currentPeriodEnd      DateTime?          @map("current_period_end")
  trialEndsAt           DateTime?          @map("trial_ends_at")
  usageCounters         Json?              @map("usage_counters")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  organization          Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan                  Plan               @relation(fields: [planId], references: [id])
  orders                Order[]

  @@index([organizationId])
  @@index([planId])
  @@index([status])
  @@map("subscriptions")
}

model Order {
  id              String            @id @default(uuid()) @db.Uuid
  organizationId  String            @map("organization_id") @db.Uuid
  subscriptionId  String?           @map("subscription_id") @db.Uuid
  planId          String?           @map("plan_id") @db.Uuid
  userId          String?           @map("user_id") @db.Uuid
  orderNo         String            @unique @map("order_no")
  providerOrderNo String?           @unique @map("provider_order_no")
  provider        PaymentProvider
  status          OrderStatus       @default(PENDING)
  amountCents     Int               @map("amount_cents")
  currency        String            @default("CNY")
  subject         String
  metadata        Json?
  paidAt          DateTime?         @map("paid_at")
  expiresAt       DateTime?         @map("expires_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  subscription    Subscription?     @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  plan            Plan?             @relation(fields: [planId], references: [id], onDelete: SetNull)
  user            User?             @relation("OrderUser", fields: [userId], references: [id], onDelete: SetNull)
  callbacks       PaymentCallback[]

  @@index([organizationId])
  @@index([subscriptionId])
  @@index([planId])
  @@index([userId])
  @@index([provider, status])
  @@map("orders")
}

model PaymentCallback {
  id              String                @id @default(uuid()) @db.Uuid
  orderId         String?               @map("order_id") @db.Uuid
  provider        PaymentProvider
  callbackId      String?               @unique @map("callback_id")
  eventType       String                @map("event_type")
  status          PaymentCallbackStatus @default(RECEIVED)
  payload         Json
  signatureDigest String?               @map("signature_digest")
  receivedAt      DateTime              @default(now()) @map("received_at")
  processedAt     DateTime?             @map("processed_at")
  errorMessage    String?               @map("error_message")

  order           Order?                @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([provider, status])
  @@map("payment_callbacks")
}

model CreditAccount {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @unique @map("user_id") @db.Uuid
  balance       Decimal  @default(0) @db.Decimal(10, 2)
  totalCharged  Decimal  @default(0) @map("total_charged") @db.Decimal(10, 2)
  totalConsumed Decimal  @default(0) @map("total_consumed") @db.Decimal(10, 2)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credit_accounts")
}

model CreditTransaction {
  id                 String                @id @default(uuid()) @db.Uuid
  userId             String                @map("user_id") @db.Uuid
